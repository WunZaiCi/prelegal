{
  "_comment": "Single source of truth for the document-type registry (PL-6). Consumed by the frontend (lib/documents.ts) and the backend (app/documents.py). 'nda' documents use the bespoke Mutual NDA pipeline; 'generic' documents are driven by their keyTerms. Field types: text | textarea | date | number | select | party. A 'party' field expands into <key>_company, <key>_name, <key>_title, <key>_notice.",
  "documents": [
    {
      "id": "mutual-nda",
      "name": "Mutual NDA",
      "kind": "nda",
      "description": "Mutual Non-Disclosure Agreement: two parties exchange and protect each other's confidential information. Best when both sides will share sensitive information while exploring a relationship."
    },
    {
      "id": "cloud-service-agreement",
      "name": "Cloud Service Agreement",
      "kind": "generic",
      "description": "For a provider giving a customer access to a cloud/SaaS product: covers access, support, customer content, fees, and liability.",
      "keyTerms": [
        { "key": "provider", "label": "Provider", "type": "party", "hint": "The company providing the cloud service." },
        { "key": "customer", "label": "Customer", "type": "party", "hint": "The company using the cloud service." },
        { "key": "cloudService", "label": "Cloud Service", "type": "text", "hint": "Name of the product/service being provided." },
        { "key": "subscriptionTerm", "label": "Subscription Term", "type": "text", "hint": "e.g. 1 year, auto-renewing." },
        { "key": "fees", "label": "Fees", "type": "textarea", "hint": "Pricing and payment terms." },
        { "key": "effectiveDate", "label": "Effective Date", "type": "date" },
        { "key": "governingLaw", "label": "Governing Law", "type": "text", "hint": "e.g. Delaware." },
        { "key": "jurisdiction", "label": "Jurisdiction", "type": "text", "hint": "Courts that have jurisdiction." }
      ]
    },
    {
      "id": "design-partner-agreement",
      "name": "Design Partner Agreement",
      "kind": "generic",
      "description": "For an early-access design partnership: a partner gets early product access and gives feedback to the provider.",
      "keyTerms": [
        { "key": "provider", "label": "Provider", "type": "party" },
        { "key": "partner", "label": "Partner", "type": "party" },
        { "key": "product", "label": "Product", "type": "text", "hint": "The product the partner gets early access to." },
        { "key": "program", "label": "Program", "type": "textarea", "hint": "What the design-partner program involves." },
        { "key": "term", "label": "Term", "type": "text", "hint": "Length of the partnership." },
        { "key": "fees", "label": "Fees", "type": "textarea", "hint": "Fees, if any (often none)." },
        { "key": "effectiveDate", "label": "Effective Date", "type": "date" },
        { "key": "governingLaw", "label": "Governing Law", "type": "text" },
        { "key": "jurisdiction", "label": "Jurisdiction", "type": "text" }
      ]
    },
    {
      "id": "service-level-agreement",
      "name": "Service Level Agreement",
      "kind": "generic",
      "description": "Defines uptime targets, response times, and service credits for a cloud service. Usually accompanies a Cloud Service Agreement.",
      "keyTerms": [
        { "key": "provider", "label": "Provider", "type": "party" },
        { "key": "customer", "label": "Customer", "type": "party" },
        { "key": "uptimeTarget", "label": "Uptime Target", "type": "text", "hint": "e.g. 99.9% per month." },
        { "key": "responseTimes", "label": "Response Time Targets", "type": "textarea", "hint": "Support response targets by severity." },
        { "key": "serviceCredits", "label": "Service Credits", "type": "textarea", "hint": "Credits when targets are missed." },
        { "key": "effectiveDate", "label": "Effective Date", "type": "date" },
        { "key": "governingLaw", "label": "Governing Law", "type": "text" }
      ]
    },
    {
      "id": "professional-services-agreement",
      "name": "Professional Services Agreement",
