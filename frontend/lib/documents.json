    {
      "id": "business-associate-agreement",
      "name": "Business Associate Agreement",
      "kind": "generic",
      "description": "Addresses HIPAA business-associate obligations: permitted uses and disclosures of PHI, safeguards, and assessments.",
      "keyTerms": [
        { "key": "coveredEntity", "label": "Covered Entity", "type": "party" },
        { "key": "businessAssociate", "label": "Business Associate", "type": "party" },
        { "key": "permittedUses", "label": "Permitted Uses & Disclosures of PHI", "type": "textarea" },
        { "key": "term", "label": "Term", "type": "text" },
        { "key": "effectiveDate", "label": "Effective Date", "type": "date" },
        { "key": "governingLaw", "label": "Governing Law", "type": "text" }
      ]
    },
    {
      "id": "ai-addendum",
      "name": "AI Addendum",
      "kind": "generic",
      "description": "Supplements an agreement to cover use of AI services: restrictions, model training, IP, and privacy.",
      "keyTerms": [
